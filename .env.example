# ============================================
# openOii-ts Backend Configuration
# 复制此文件为 .env 后填写实际值
# ============================================

# ── 基础设置 ──
APP_NAME=openOii-backend
NODE_ENV=dev
LOG_LEVEL=info
PORT=3000

# ── 数据库 (PostgreSQL) ──
DATABASE_URL=postgres://postgres:postgres@localhost:5432/openoii

# ── Redis (确认信号 + BullMQ) ──
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# ── CORS ──
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Admin Token ──
ADMIN_TOKEN=

# ════════════════════════════════════════════
# LLM 服务 (Anthropic 兼容接口)
# ════════════════════════════════════════════

# 模型名称
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# 【方式一】直连 Anthropic
# ANTHROPIC_API_KEY=sk-ant-xxx

# 【方式二】中转站（推荐，国内可用）
ANTHROPIC_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ANTHROPIC_AUTH_TOKEN=your_auth_token_here

# ════════════════════════════════════════════
# 文本生成 (OpenAI 兼容接口)
# ════════════════════════════════════════════

# 可选值: anthropic | openai | fake
TEXT_PROVIDER=anthropic
TEXT_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
TEXT_API_KEY=your_text_api_key
TEXT_MODEL=deepseek-v4-flash
TEXT_ENDPOINT=/
TEXT_ENABLE_THINKING=false
# Fake 文本 Provider 的固定响应（仅 TEXT_PROVIDER=fake 时生效）
FAKE_TEXT_RESPONSE=

# ════════════════════════════════════════════
# 图像生成 (OpenAI 兼容接口)
# ════════════════════════════════════════════

# 可选值: openai | fake
IMAGE_PROVIDER=openai
IMAGE_BASE_URL=https://api.openai.com/v1
IMAGE_API_KEY=your_image_api_key
IMAGE_MODEL=dall-e-3
IMAGE_ENDPOINT=/images/generations
# 图生图开关
ENABLE_IMAGE_TO_IMAGE=false
# Fake 图像 Provider 的固定 URL（仅 IMAGE_PROVIDER=fake 时生效）
FAKE_IMAGE_FIXTURE_URL=

# ════════════════════════════════════════════
# 视频生成 (OpenAI 兼容接口 | 豆包 Seedance)
# ════════════════════════════════════════════

# 可选值: openai | doubao | fake
VIDEO_PROVIDER=openai
# OpenAI 兼容视频
VIDEO_BASE_URL=https://api.example.com/v1
VIDEO_API_KEY=your_video_api_key
VIDEO_MODEL=video-gen-1
VIDEO_ENDPOINT=/videos/generations
VIDEO_MODE=text
ENABLE_IMAGE_TO_VIDEO=false
# 图生视频模式: first_frame | reference
VIDEO_IMAGE_MODE=first_frame
VIDEO_INLINE_LOCAL_IMAGES=true
# 豆包视频（仅 VIDEO_PROVIDER=doubao）
DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_VIDEO_MODEL=doubao-seedance-1-5-pro-251215
DOUBAO_VIDEO_DURATION=5
DOUBAO_VIDEO_RATIO=adaptive
DOUBAO_GENERATE_AUDIO=true
# Fake 视频
# FAKE_VIDEO_FIXTURE_URL=/static/videos/dev_clip.mp4
# FAKE_VIDEO_FIXTURE_PATH=/absolute/path/to/dev_clip.mp4

# ════════════════════════════════════════════
# TTS / BGM
# ════════════════════════════════════════════
TTS_ENABLED=true
TTS_DEFAULT_VOICE=zh-CN-XiaoxiaoNeural
TTS_VOLUME=1.0
BGM_ENABLED=true
BGM_VOLUME=0.3
BGM_DIRECTORY=static/bgm

# ════════════════════════════════════════════
# 工作流控制
# ════════════════════════════════════════════

# 思考链可视化
THINKING_CHAIN_ENABLED=true
THINKING_CHAIN_DETAIL_LEVEL=normal

# Critic 质量审查
CRITIQUE_ENABLED=true
CRITIQUE_SCORE_THRESHOLD=6.0
CRITIQUE_MAX_ROUNDS=2

# 大纲审批
OUTLINE_ENABLED=true

# 请求超时（秒）
REQUEST_TIMEOUT_S=120.0

# 对外可访问 URL（用于生成 /static 完整 URL）
PUBLIC_BASE_URL=http://localhost:3000
